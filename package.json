{
  "name": "@sendcraft/cli",
  "version": "1.0.0",
  "description": "The official CLI for SendCraft — send emails, manage campaigns, and more from your terminal",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "sendcraft": "./src/cli.js"
  },
  "scripts": {
    "dev": "node src/cli.js",
    "build": "npx esbuild src/cli.js --bundle --platform=node --target=node18 --format=cjs --outfile=dist/cli.cjs --external:fsevents",
    "build:bin": "npm run build && npx pkg dist/cli.cjs --targets node18-linux-x64,node18-macos-x64,node18-macos-arm64,node18-win-x64 --compress Brotli --output dist/sendcraft",
    "prepublishOnly": "npm run build",
    "test": "echo \"No tests yet\""
  },
  "files": [
    "src/",
    "dist/cli.cjs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "sendcraft",
    "email",
    "cli",
    "transactional",
    "marketing"
  ],
  "author": "SendCraft Team <sendcraft.team@gmail.com>",
  "homepage": "https://github.com/sendcraftlabs/sendcraft-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sendcraftlabs/sendcraft-cli.git"
  },
  "bugs": {
    "url": "https://github.com/sendcraftlabs/sendcraft-cli/issues"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^4.1.2",
    "chrono-node": "^2.7.6",
    "cli-table3": "^0.6.5",
    "commander": "^11.1.0",
    "gradient-string": "^3.0.0",
    "ora": "^5.4.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "pkg": "^5.8.1"
  }
}
